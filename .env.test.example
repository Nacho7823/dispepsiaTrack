# Stagehand E2E Test Environment Variables
# Copy this to .env.test and fill in your values

# Required: API key for Stagehand's LLM (browser automation AI)
# Use Anthropic or OpenAI
ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here

# Optional: override the default model (claude-sonnet-4-20250514)
# STAGEHAND_MODEL=claude-sonnet-4-20250514
